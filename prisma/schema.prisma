generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  OWNER
}

enum Type {
  IN
  OUT
}

enum Category {
  SALE
  RESTOCK
  LOAN
  RETURN
}

model User {
  id        Int @id @default(autoincrement())
  username  String @unique
  password  String
  role      Role

  products  Product[]
  restocks  Restock[]
  customers Customer[]
  sales     Sale[]
  cashflows  CashFlow[]
}

model Product {
  id        Int @id @default(autoincrement())
  name      String
  price     Int
  stock     Int
  createdAt DateTime @default(now())

  restocks  Restock[]
  sales     Sale[]


  userId    Int
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Restock {
  id        Int @id @default(autoincrement())
  qty       Int
  costPrice Int
  createdAt DateTime @default(now())

  userId    Int
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

model Customer {
  id        Int @id @default(autoincrement())
  name      String
  phone     String @unique
  createdAt DateTime @default(now())

  sales     Sale[]

  userId    Int
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Sale {
  id         Int @id @default(autoincrement())
  qty        Int
  price      Int
  total      Int
  createdAt  DateTime @default(now())

  userId     Int
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([customerId])
}

model CashFlow {
  id        Int @id @default(autoincrement())
  type      Type
  category  Category
  amount    Int
  note      String
  createdAt DateTime @default(now())

  userId    Int
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}